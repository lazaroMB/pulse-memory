# ArcadeDB Database Settings
ARCADEDB_URL=http://localhost:2480
ARCADEDB_DATABASE=pulse
ARCADEDB_USERNAME=root
ARCADEDB_PASSWORD=playwithdata

# LLM Provider Configuration
# Supported values: gemini (default), openai
LLM_PROVIDER=gemini

# Generic API Credentials (optional fallback)
# LLM_API_KEY=your_generic_api_key_here

# Gemini AI Integration Settings
# Get your key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_GENERATION_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# OpenAI AI Integration Settings
# Get your key from OpenAI Platform: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_GENERATION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Server Configuration
PORT=8080

# Dynamic Embedding Batcher Settings (optimized for high-concurrency swarm environments)
EMBEDDING_BATCH_SIZE=100
EMBEDDING_LINGER_MS=10
EMBEDDING_QUEUE_CAPACITY=5000

# Consolidation Background Worker Settings
CONSOLIDATION_MAX_WORKERS=5
CONSOLIDATION_QUEUE_SIZE=500

# Short-Term Chat Memory Settings
# Supported providers: redis, valkey, in-memory
CHAT_MEMORY_PROVIDER=redis
CHAT_MEMORY_URL=localhost:6379

# Forgetting Curve Memory Decay Configuration
# Default initial stability in days for long-term facts and relations (default fallback: 30.0 days/1 month)
DEFAULT_MEMORY_STABILITY_DAYS=30
