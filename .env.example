# Database Provider Configuration
# Supported values: postgres (default), neo4j, falkordb
DB_PROVIDER=postgres

# PostgreSQL with pgvector settings
# Format: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/swarm_mem?sslmode=disable

# Neo4j Graph Settings
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# FalkorDB Settings
FALKORDB_URL=localhost:6379
FALKORDB_GRAPH_NAME=swarm_memory

# LLM Provider Configuration
# Supported values: gemini (default), openai
LLM_PROVIDER=gemini

# Generic API Credentials (optional fallback)
# LLM_API_KEY=your_generic_api_key_here

# Gemini AI Integration Settings
# Get your key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_GENERATION_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# OpenAI AI Integration Settings
# Get your key from OpenAI Platform: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_GENERATION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Server Configuration
PORT=8080
